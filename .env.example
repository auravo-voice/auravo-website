# PocketBase (auth + data)
NEXT_PUBLIC_POCKETBASE_URL=https://pb.auravo.ai
# Public site URL for OAuth callbacks (optional; defaults to request host). Set on Vercel if redirects break.
# NEXT_PUBLIC_APP_URL=https://app.auravo.ai

# Ollama (server-side only — never sent to the browser)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Max time (ms) to wait for each coach Ollama call. Default 120000 (2 min). 7b is slower — try 180000–240000 on small VPSes.
# AURAVO_COACH_TIMEOUT_MS=120000
# Alias: OLLAMA_TIMEOUT_MS

# Transcription (initial assessment + practice sessions). faster-whisper needs ffmpeg on PATH and a project venv:
#   npm run setup:transcription
# Uses .venv-transcription/bin/python automatically when present (override with FASTER_WHISPER_PYTHON).
# Do not set PYTHON=python3 in .env — that forces system Python (usually without faster-whisper). Use
# FASTER_WHISPER_PYTHON=/absolute/path/to/auravo-web/.venv-transcription/bin/python if you need an override.
# On macOS + Homebrew Python 3.14, the app prepends Homebrew expat to DYLD_LIBRARY_PATH for the child process.
# TRANSCRIPTION_PROVIDER=placeholder
# TRANSCRIPTION_PROVIDER=faster-whisper
# FASTER_WHISPER_MODEL=base
# FASTER_WHISPER_TIMEOUT_MS=120000
# FASTER_WHISPER_PYTHON=python3

# When TRANSCRIPTION_PROVIDER=faster-whisper, the practice route refuses to silently fall back to the
# placeholder if the model fails. In early dev you can flip this on to keep working without recording:
# AURAVO_ALLOW_PLACEHOLDER_FALLBACK=0

# Optional: local acoustic features (openSMILE eGeMAPSv02). Bundled with the `opensmile` Python package
# installed by `npm run setup:transcription`. If the package is not available the analysis pipeline still
# runs — it just marks clarity / confidence / pronunciation scores as transcript-only.
# OPENSMILE_TIMEOUT_MS=60000

# Optional: local Voice Activity Detection. `npm run setup:transcription` installs `silero-vad` (preferred,
# ML-grade) on Python <3.14 and `webrtcvad-wheels` (lightweight C fallback) everywhere. With neither
# package installed, pause/silence metrics fall back to word-gap heuristics — the rest of analysis is unaffected.
# AURAVO_VAD_PROVIDER=silero   # force a specific provider (silero | webrtcvad)
# VAD_TIMEOUT_MS=45000

# In-memory LRU so repeat analysis of the same uploaded file skips re-running openSMILE/VAD subprocesses in one
# server process. Disabled when 0. Overrides: AURAVO_AUDIO_FEATURE_CACHE_MAX, else OPENSMILE_CACHE_MAX, else VAD_CACHE_MAX.
# AURAVO_AUDIO_FEATURE_CACHE_MAX=48

# Dev only: when you open the app from another host (e.g. phone at http://192.168.1.37:3000),
# Next.js blocks HMR / _next dev assets unless that host is allowlisted. Comma-separated hosts or URLs.
# Restart `npm run dev` after changing. Production (`next start`) does not use this.
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.37
