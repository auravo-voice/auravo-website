# --- Storage backend ---
# sqlite (default): local ./data/auravo.sqlite — recommended for dev
# pocketbase: all session/scores data on PocketBase (see docs/POCKETBASE.md)
AURAVO_STORAGE=sqlite
# AURAVO_DB_DIR=/absolute/path/to/data
# AURAVO_DB_FILE=auravo.sqlite

# PocketBase: required for Google / email auth; optional when AURAVO_STORAGE=sqlite (auth only)
NEXT_PUBLIC_POCKETBASE_URL=https://pb.auravo.ai
# Server-only internal URL (container → auth on private network). Leave unset on Vercel.
# POCKETBASE_URL=http://auth:8080
# NEXT_PUBLIC_APP_URL=https://app.auravo.ai
# Comma-separated user ids allowed to access /observability (works in sqlite + pocketbase modes)
# AURAVO_ADMIN_USER_IDS=pb_user_id_1,pb_user_id_2
# Optional PocketBase role string to treat as admin when auth record has `role` or `roles`
# AURAVO_ADMIN_ROLE_VALUE=admin

# Groq — transcript pattern coaching (assessment finalize, practice, etc.)
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (optional — dashboard narrative, task review, simulations; not used for transcript coaching)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://host.containers.internal:11434
# OLLAMA_MODEL=gemma2:2b

FASTER_WHISPER_MODEL=small

# Transcription
# TRANSCRIPTION_PROVIDER=faster-whisper
# FASTER_WHISPER_MODEL=base
# FASTER_WHISPER_PYTHON=/path/to/.venv-transcription/bin/python
# AURAVO_ALLOW_PLACEHOLDER_FALLBACK=0

# Dev: LAN testing from phone
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.37
