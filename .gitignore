# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
Desktop.ini
*.pem
*.key

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# TypeScript incremental
*.tsbuildinfo

# eslint
.eslintcache

# turborepo (if used later)
.turbo

# vercel
.vercel

# --- Secrets & local env (keep templates like .env.example committed) ---
.env
.env.*
!.env.example
!.env.*.example

# --- Local runtime data (SQLite DB, WAL, journals, uploads, handoff blobs) ---
/data/

# --- Local Python (faster-whisper / transcription); run `npm run setup:transcription` ---
/.venv-transcription/
.venv/
venv/
__pycache__/
*.py[cod]

# --- IDE / editor (may contain machine paths or tokens) ---
.idea/
*.swp
*.swo
*~
